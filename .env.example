# =====================================================
# botme.neeklo.ru — переменные окружения
# Скопируй файл в .env и подставь реальные значения.
# .env закоммичен в .gitignore и НИКОГДА не попадает в git.
# =====================================================

# --- Ollama (qwen2.5-coder и др., OpenAI-совместимый API) ---
OLLAMA_BASE_URL=https://ollama.siteaacess.store/v1
OLLAMA_TOKEN=

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=

# --- Google Gemini (AI Studio) ---
GEMINI_API_KEY=

# --- OpenAI (LLM + embeddings text-embedding-3-small для RAG) ---
OPENAI_API_KEY=

# --- xAI / Grok (OpenAI-совместимый API) ---
# Получить ключ: https://console.x.ai → API Keys.
# Доступ к моделям семейства Grok (grok-4, grok-4-fast, grok-3, grok-3-mini, grok-code-fast-1).
# Можно использовать XAI_API_KEY или GROK_API_KEY (любой из двух).
XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1   # по умолчанию так и есть

# --- OpenRouter (единый OpenAI-compatible API; модели с tools подтягиваются в /api/models) ---
# Ключ: https://openrouter.ai/keys — не коммитить, только в .env на сервере.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # по умолчанию так и есть
# OPENROUTER_HTTP_REFERER=https://botme.neeklo.ru  # для статистики OpenRouter (опционально)
# OPENROUTER_APP_TITLE=Botme

# --- HTTP-порт Node.js процесса ---
# Локально: 3001. На VPS botme.neeklo.ru: 3015 (порт 3001 уже занят другим приложением).
# Nginx проксирует https://botme.neeklo.ru -> http://127.0.0.1:${PORT}
PORT=3001

# --- Окружение (опционально) ---
NODE_ENV=production

# --- Сессия входа в админку (обязательно в production: случайная строка 32+ символов) ---
SESSION_SECRET=

# --- Context7 (актуальная документация библиотек для уменьшения галлюцинаций модели) ---
# Получить ключ: https://context7.com/dashboard → API Keys → Create. Префикс ctx7sk-...
# При выставленном ключе сервер автоматически дёргает Context7 для упоминаемых библиотек
# (Tailwind, AOS, GSAP, Lucide, Swiper, ...) и подмешивает свежие сниппеты в системный промпт.
# Чтобы выключить без удаления ключа: CONTEXT7_DISABLED=1
CONTEXT7_API_KEY=
# CONTEXT7_DISABLED=

# --- Replicate (AI Media Studio: image / video / upscale) ---
# Получить ключ: https://replicate.com/account/api-tokens . Префикс r8_...
# При отсутствии токена узлы Image / Video / Upscale возвращают понятную ошибку
# и работа на канвасе продолжается без сбоев (узлы Text / Assistant работают).
REPLICATE_API_TOKEN=

# --- ElevenLabs (AI Media Studio: TTS / Audio Generator) ---
# Получить ключ: https://elevenlabs.io/app/settings/api-keys.
# Без него узлы Audio (TTS) показывают предупреждение и не запускаются;
# остальные узлы продолжают работать.
ELEVENLABS_API_KEY=

# --- Site Builder Agent (Phase B-F) ---
# Базовый URL для внутренних smoke-тестов. Используется Playwright-ом, чтобы
# открыть /preview/<id>/. Должен указывать на этот же процесс на 127.0.0.1.
# По умолчанию http://127.0.0.1:${PORT}
# INTERNAL_PREVIEW_BASE_URL=http://127.0.0.1:3015

# Отключить Playwright (smoke-тест) и сразу падать на jsdom-fallback.
# Полезно если Chromium не установлен или валится по памяти.
# PLAYWRIGHT_DISABLED=1

# Отключить react-bundle режим (Architect будет всегда выбирать static).
# ESBUILD_DISABLED=1

# Папка для shared node_cache react-bundle проектов. По умолчанию ~/.botme-node-cache
# ESBUILD_CACHE_DIR=/var/www/botme/data/node_cache

# --- SMTP: общая отправка уведомлений о лидах (опционально) ---
# Если заданы SMTP_HOST и SMTP_FROM на сервере (например botme.neeklo.ru), каждому ассистенту достаточно
# включить email и указать только адрес получателя в админке.
# SMTP_USER / SMTP_PASS — если провайдер требует авторизацию.
# SMTP_SECURE=1 — implicit TLS (часто порт 465).
# SMTP_TLS_REJECT_UNAUTHORIZED=0 — только для своего SMTP с самоподписанным сертификатом.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
