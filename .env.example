# =====================================================
# botme.neeklo.ru — переменные окружения
# Скопируй файл в .env и подставь реальные значения.
# .env закоммичен в .gitignore и НИКОГДА не попадает в git.
# =====================================================

# --- Ollama (qwen2.5-coder и др., OpenAI-совместимый API) ---
OLLAMA_BASE_URL=https://ollama.siteaacess.store/v1
OLLAMA_TOKEN=

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=

# --- Google Gemini (AI Studio) ---
GEMINI_API_KEY=

# --- OpenAI (LLM + embeddings text-embedding-3-small для RAG) ---
OPENAI_API_KEY=

# --- OpenRouter (единый OpenAI-compatible API; модели с tools подтягиваются в /api/models) ---
# Ключ: https://openrouter.ai/keys — не коммитить, только в .env на сервере.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # по умолчанию так и есть
# OPENROUTER_HTTP_REFERER=https://botme.neeklo.ru  # для статистики OpenRouter (опционально)
# OPENROUTER_APP_TITLE=Botme

# --- HTTP-порт Node.js процесса ---
# Локально: 3001. На VPS botme.neeklo.ru: 3015 (порт 3001 уже занят другим приложением).
# Nginx проксирует https://botme.neeklo.ru -> http://127.0.0.1:${PORT}
PORT=3001

# --- Окружение (опционально) ---
NODE_ENV=production
